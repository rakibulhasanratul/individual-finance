# Database connection URL for NeonDB (pooled, recommended for app/runtime queries)
# Get this from your Neon project dashboard
DATABASE_URL="postgresql://username:password@host/neondb?sslmode=require"

# Direct connection URL for Prisma migrations/introspection (non-pooled)
# Get this from your Neon project dashboard
DIRECT_URL="postgresql://username:password@host/neondb?sslmode=require"

# Auth.js secret for session signing
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"