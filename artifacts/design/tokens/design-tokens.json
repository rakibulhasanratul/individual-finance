{
  "meta": {
    "name": "individual-finance-design-tokens",
    "version": "1.0.0",
    "mode": "light-dark",
    "principles": ["clarity", "trust", "determinism", "non-judgmental"]
  },
  "color": {
    "light": {
      "bg": { "canvas": "#F8FAFC", "surface": "#FFFFFF", "subtle": "#EEF2F7" },
      "text": {
        "primary": "#0F172A",
        "secondary": "#334155",
        "muted": "#64748B",
        "inverse": "#FFFFFF"
      },
      "border": { "default": "#CBD5E1", "strong": "#94A3B8" },
      "brand": {
        "primary": "#1D4ED8",
        "primaryHover": "#1E40AF",
        "primarySoft": "#DBEAFE"
      },
      "status": {
        "success": "#15803D",
        "successSoft": "#DCFCE7",
        "warning": "#B45309",
        "warningSoft": "#FEF3C7",
        "danger": "#B91C1C",
        "dangerSoft": "#FEE2E2",
        "info": "#1D4ED8",
        "infoSoft": "#DBEAFE"
      },
      "role": {
        "admin": "#4338CA",
        "adminSoft": "#E0E7FF",
        "obligationCurrent": "#1D4ED8",
        "obligationUpcoming": "#B45309",
        "obligationOverdue": "#B91C1C",
        "invariantPass": "#15803D",
        "invariantFail": "#B91C1C"
      },
      "overlay": { "scrim": "rgba(15,23,42,0.55)" }
    },
    "dark": {
      "bg": { "canvas": "#020617", "surface": "#0B1220", "subtle": "#111827" },
      "text": {
        "primary": "#E2E8F0",
        "secondary": "#CBD5E1",
        "muted": "#94A3B8",
        "inverse": "#020617"
      },
      "border": { "default": "#334155", "strong": "#475569" },
      "brand": {
        "primary": "#60A5FA",
        "primaryHover": "#93C5FD",
        "primarySoft": "#1E3A8A"
      },
      "status": {
        "success": "#22C55E",
        "successSoft": "#14532D",
        "warning": "#F59E0B",
        "warningSoft": "#78350F",
        "danger": "#F87171",
        "dangerSoft": "#7F1D1D",
        "info": "#60A5FA",
        "infoSoft": "#1E3A8A"
      },
      "role": {
        "admin": "#818CF8",
        "adminSoft": "#312E81",
        "obligationCurrent": "#60A5FA",
        "obligationUpcoming": "#F59E0B",
        "obligationOverdue": "#F87171",
        "invariantPass": "#22C55E",
        "invariantFail": "#F87171"
      },
      "overlay": { "scrim": "rgba(2,6,23,0.65)" }
    }
  },
  "typography": {
    "fontFamily": {
      "body": "\"Manrope\", \"Noto Sans\", system-ui, sans-serif",
      "heading": "\"Sora\", \"Noto Sans\", system-ui, sans-serif",
      "monoNumeric": "\"IBM Plex Mono\", \"Roboto Mono\", monospace"
    },
    "size": {
      "xs": "12px",
      "sm": "14px",
      "md": "16px",
      "lg": "18px",
      "xl": "20px",
      "2xl": "24px",
      "3xl": "30px"
    },
    "lineHeight": { "tight": 1.2, "normal": 1.5, "relaxed": 1.65 },
    "weight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
    "tracking": { "tight": "-0.01em", "normal": "0", "wide": "0.01em" }
  },
  "spacing": {
    "0": "0px",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "8": "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px"
  },
  "radius": {
    "sm": "6px",
    "md": "10px",
    "lg": "14px",
    "xl": "20px",
    "pill": "999px"
  },
  "shadow": {
    "sm": "0 1px 2px rgba(15,23,42,0.06)",
    "md": "0 4px 12px rgba(15,23,42,0.10)",
    "lg": "0 10px 30px rgba(15,23,42,0.14)"
  },
  "motion": {
    "duration": { "fast": "120ms", "base": "200ms", "slow": "280ms" },
    "easing": {
      "standard": "cubic-bezier(0.2,0,0,1)",
      "exit": "cubic-bezier(0.4,0,1,1)"
    },
    "reducedMotion": { "enabled": true }
  },
  "zIndex": {
    "base": 0,
    "dropdown": 100,
    "sticky": 200,
    "overlay": 400,
    "modal": 500,
    "toast": 600
  },
  "component": {
    "touchTargetMin": "44px",
    "inputHeight": { "sm": "40px", "md": "44px", "lg": "48px" },
    "button": {
      "primaryBg": "{color.light.brand.primary}",
      "primaryText": "{color.light.text.inverse}",
      "disabledOpacity": 0.45
    },
    "statusBadge": {
      "current": "{color.light.role.obligationCurrent}",
      "upcoming": "{color.light.role.obligationUpcoming}",
      "overdue": "{color.light.role.obligationOverdue}"
    }
  }
}
